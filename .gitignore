# Environment variables (real keys)
.env

# Google OAuth tokens (share-doc) — personal to each student
# NOTE: google-client-credentials.json is deliberately IN the repo (it's safe, not secret)
.google-token.json

# Student working files (their adapted prompts, exports, campaigns, strategy docs)
# These are personal to each student and should not be pushed back
prompts/adapted/**/*.txt
prompts/adapted/**/*.json
campaigns/drafts/**/*.md
campaigns/drafts/**/*.csv
campaigns/approved/**/*.md
campaigns/approved/**/*.csv
clay-exports/*.csv
clay-exports/*.json
strategy/*.md
strategy/*.pdf

# OS and editor
.DS_Store
Thumbs.db
*.swp
*.swo

# Node (if students run scripts)
node_modules/
*.log

# Claude Code local state
.claude/projects/

# Keep folder structure
!**/.gitkeep
